# Database - MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=ai_evaluation

# JWT
SECRET_KEY=your-super-secret-key-change-in-production

# AI Settings
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
AI_PROVIDER=openai
EVALUATION_MODE=medium

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aievaluation.com
